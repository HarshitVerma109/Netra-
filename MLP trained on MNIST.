import numpy as np
import matplotlib.pyplot as plt
import torch
import torch.nn as nn
import torch.optim as optim
import torchvision
import torchvision.transforms as transforms
from torch.utils.data import DataLoader
import copy
import seaborn as sns

print("PyTorch version:", torch.__version__)
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Device: {device}")

transform = transforms.Compose([transforms.ToTensor(), transforms.Normalize((0.1307,), (0.3081,))])
train_dataset = torchvision.datasets.MNIST(root='./data', train=True, download=True, transform=transform)
test_dataset = torchvision.datasets.MNIST(root='./data', train=False, download=True, transform=transform)
batch_size = 64
train_loader = DataLoader(train_dataset, batch_size=batch_size, shuffle=True)
test_loader = DataLoader(test_dataset, batch_size=batch_size, shuffle=False)
print(f"Training samples: {len(train_dataset)}, Test samples: {len(test_dataset)}")

class MLP(nn.Module):
    def __init__(self):
        super().__init__()
        self.network = nn.Sequential(nn.Flatten(), nn.Linear(784, 512), nn.ReLU(), nn.Linear(512, 256), nn.ReLU(), nn.Linear(256, 128), nn.ReLU(), nn.Linear(128, 10))
    def forward(self, x):
        return self.network(x)

def xavier_init(model):
    for layer in model.modules():
        if isinstance(layer, nn.Linear):
            nn.init.xavier_uniform_(layer.weight)
            if layer.bias is not None:
                nn.init.zeros_(layer.bias)
    return model

def kaiming_init(model):
    for layer in model.modules():
        if isinstance(layer, nn.Linear):
            nn.init.kaiming_uniform_(layer.weight, nonlinearity='relu')
            if layer.bias is not None:
                nn.init.zeros_(layer.bias)
    return model

def train_model(model, train_loader, criterion, optimizer, epochs=10):
    model.train()
    train_losses, train_accs = [], []
    for epoch in range(epochs):
        epoch_loss, correct, total = 0, 0, 0
        for images, labels in train_loader:
            images, labels = images.to(device), labels.to(device)
            logits = model(images)
            loss = criterion(logits, labels)
            optimizer.zero_grad()
            loss.backward()
            optimizer.step()
            epoch_loss += loss.item()
            preds = logits.argmax(dim=1)
            correct += (preds == labels).sum().item()
            total += labels.size(0)
        train_losses.append(epoch_loss / len(train_loader))
        train_accs.append(100 * correct / total)
    return train_losses, train_accs

learning_rates = [0.0001, 0.001, 0.01]
initializations = {'Xavier': xavier_init, 'Kaiming': kaiming_init}
num_epochs = 15
criterion = nn.CrossEntropyLoss()
results = {}
exp_num = 1

for init_name, init_func in initializations.items():
    for lr in learning_rates:
        print(f"\n[Experiment {exp_num}/{len(learning_rates)*len(initializations)}] Init: {init_name}, LR: {lr}")
        model = MLP().to(device)
        model = init_func(model)
        optimizer = optim.SGD(model.parameters(), lr=lr)
        train_losses, train_accs = train_model(model, train_loader, criterion, optimizer, epochs=num_epochs)
        key = f"{init_name}_LR{lr}"
        results[key] = {'losses': train_losses, 'accuracies': train_accs, 'final_loss': train_losses[-1], 'final_acc': train_accs[-1], 'lr': lr, 'init': init_name}
        print(f"  Final Loss: {train_losses[-1]:.4f}, Final Acc: {train_accs[-1]:.2f}%")
        exp_num += 1

epochs_range = range(1, num_epochs + 1)
colors = {'0.0001': 'blue', '0.001': 'green', '0.01': 'red'}
linestyles = {'Xavier': '-', 'Kaiming': '--'}

fig, axes = plt.subplots(1, 2, figsize=(14, 5))
for key, data in results.items():
    lr_str = str(data['lr'])
    label = f"{data['init']} LR={data['lr']}"
    axes[0].plot(epochs_range, data['losses'], color=colors[lr_str], linestyle=linestyles[data['init']], linewidth=2, label=label)
    axes[1].plot(epochs_range, data['accuracies'], color=colors[lr_str], linestyle=linestyles[data['init']], linewidth=2, label=label)
axes[0].set_title("Training Loss: All Experiments"); axes[0].set_xlabel("Epoch"); axes[0].set_ylabel("Loss"); axes[0].legend(fontsize=9); axes[0].grid(True, alpha=0.3)
axes[1].set_title("Training Accuracy: All Experiments"); axes[1].set_xlabel("Epoch"); axes[1].set_ylabel("Accuracy (%)"); axes[1].legend(fontsize=9); axes[1].grid(True, alpha=0.3)
plt.tight_layout(); plt.show()

fig, axes = plt.subplots(1, 3, figsize=(16, 4))
for idx, lr in enumerate(learning_rates):
    for init_name in initializations.keys():
        key = f"{init_name}_LR{lr}"
        if key in results:
            axes[idx].plot(epochs_range, results[key]['losses'], marker='o', linewidth=2, label=init_name)
    axes[idx].set_title(f"Learning Rate = {lr}"); axes[idx].set_xlabel("Epoch"); axes[idx].set_ylabel("Loss"); axes[idx].legend(); axes[idx].grid(True, alpha=0.3)
plt.suptitle("Loss Curves Grouped by Learning Rate", fontsize=14); plt.tight_layout(); plt.show()

fig, axes = plt.subplots(1, 2, figsize=(12, 4))
for idx, init_name in enumerate(initializations.keys()):
    for lr in learning_rates:
        key = f"{init_name}_LR{lr}"
        if key in results:
            axes[idx].plot(epochs_range, results[key]['losses'], marker='o', linewidth=2, label=f"LR={lr}")
    axes[idx].set_title(f"Initialization: {init_name}"); axes[idx].set_xlabel("Epoch"); axes[idx].set_ylabel("Loss"); axes[idx].legend(); axes[idx].grid(True, alpha=0.3)
plt.suptitle("Loss Curves Grouped by Initialization", fontsize=14); plt.tight_layout(); plt.show()

print("\nEXPERIMENT RESULTS SUMMARY")
sorted_results = sorted(results.items(), key=lambda x: x[1]['final_loss'])
for key, data in sorted_results:
    convergence = "Fast" if data['final_loss'] < 0.2 else "Slow" if data['final_loss'] < 0.5 else "Poor"
    print(f"{data['init']:<15} LR={data['lr']:<8} Loss={data['final_loss']:.4f}  Acc={data['final_acc']:.2f}%  [{convergence}]")

def analyze_convergence(losses, threshold=0.3):
    for epoch, loss in enumerate(losses, 1):
        if loss < threshold:
            return epoch
    return None

for init_name in initializations.keys():
    print(f"\n{init_name} Initialization:")
    for lr in learning_rates:
        key = f"{init_name}_LR{lr}"
        epoch = analyze_convergence(results[key]['losses'])
        print(f"  LR {lr} → {'Converged at epoch ' + str(epoch) if epoch else 'Did NOT converge to 0.3'}")

for key, data in sorted(results.items()):
    std = np.std(data['losses'][-5:])
    stability = "Stable" if std < 0.01 else "Moderate" if std < 0.05 else "Unstable"
    print(f"{key:<20} Std: {std:.4f}  [{stability}]")

best_key = min(results.keys(), key=lambda k: results[k]['final_loss'])
worst_key = max(results.keys(), key=lambda k: results[k]['final_loss'])
print(f"\nBEST:  {results[best_key]['init']} + LR={results[best_key]['lr']} → Loss={results[best_key]['final_loss']:.4f}, Acc={results[best_key]['final_acc']:.2f}%")
print(f"WORST: {results[worst_key]['init']} + LR={results[worst_key]['lr']} → Loss={results[worst_key]['final_loss']:.4f}, Acc={results[worst_key]['final_acc']:.2f}%")

init_names = list(initializations.keys())
loss_matrix = np.zeros((len(initializations), len(learning_rates)))
acc_matrix = np.zeros((len(initializations), len(learning_rates)))
for i, init_name in enumerate(init_names):
    for j, lr in enumerate(learning_rates):
        key = f"{init_name}_LR{lr}"
        if key in results:
            loss_matrix[i, j] = results[key]['final_loss']
            acc_matrix[i, j] = results[key]['final_acc']

fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 4))
sns.heatmap(loss_matrix, annot=True, fmt='.4f', cmap='RdYlGn_r', xticklabels=learning_rates, yticklabels=init_names, ax=ax1, cbar_kws={'label': 'Final Loss'})
ax1.set_title("Final Training Loss"); ax1.set_xlabel("Learning Rate"); ax1.set_ylabel("Initialization")
sns.heatmap(acc_matrix, annot=True, fmt='.2f', cmap='RdYlGn', xticklabels=learning_rates, yticklabels=init_names, ax=ax2, cbar_kws={'label': 'Accuracy (%)'})
ax2.set_title("Final Training Accuracy (%)"); ax2.set_xlabel("Learning Rate"); ax2.set_ylabel("Initialization")
plt.tight_layout(); plt.show()
